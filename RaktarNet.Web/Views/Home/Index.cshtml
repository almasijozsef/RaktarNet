@model DashboardViewModel

@{
    var isAdmin = Model.CurrentUser != null && Model.CurrentUser.Role == "admin";
    var isVezeto = Model.CurrentUser != null && Model.CurrentUser.Role == "vezeto";
    var canManageProducts = isAdmin || isVezeto;
    var selectedTipus = Model.LogTipus ?? "";
}

@if (TempData["Success"] != null)
{
    <div class="alert success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert error">@TempData["Error"]</div>
}

<div class="topbar">
    <div class="topbar-left">
        <strong>RaktarNet</strong>

        <span class="user-info">
            👤 Felhasználó: @Model.CurrentUser?.Username
        </span>

        @if (isAdmin)
        {
            <span class="role-badge role-admin">admin</span>
        }
        else if (isVezeto)
        {
            <span class="role-badge role-vezeto">vezető</span>
        }
        else
        {
            <span class="role-badge role-raktaros">raktáros</span>
        }

        <span class="welcome-text">Üdv, @Model.CurrentUser?.Username!</span>
    </div>

    <a class="logout" asp-controller="Account" asp-action="Logout">Kijelentkezés</a>
</div>

<div class="container">
    @if (canManageProducts)
    {
        <div class="card">
            <h3>Áttekintés</h3>
            <div class="stats">
                <div class="stat blue"><span>Termékek száma</span><strong>@Model.Products.Count</strong></div>
                <div class="stat blue"><span>Összes darabszám</span><strong>@Model.Products.Sum(x => x.Mennyiseg)</strong></div>
                <div class="stat green"><span>Összes készletérték</span><strong>@String.Format("{0:N0} Ft", Model.Products.Sum(x => x.Mennyiseg * x.Egysegar))</strong></div>
                <div class="stat orange"><span>Naplóbejegyzések</span><strong>@Model.Logs.Count</strong></div>

                <div class="stat blue"><span>Mai mozgások</span><strong>@Model.MaiMozgasokSzama</strong></div>
                <div class="stat green"><span>Mai bevételezések</span><strong>@Model.MaiBevetelezesekSzama</strong></div>
                <div class="stat red"><span>Mai kiadások</span><strong>@Model.MaiKiadasokSzama</strong></div>
                <div class="stat red"><span>Alacsony készlet</span><strong>@Model.AlacsonyKeszletuTermekekSzama</strong></div>
            </div>
        </div>
    }

    <div class="grid">
        <div class="card">
            <h3>Készlet keresése</h3>
            <form method="get" class="inline-form">
                <input type="text" name="search" value="@Model.Search" placeholder="Termék vagy kód" />
                <button type="submit">🔎 Keresés</button>
            </form>

            <h3>Új termék</h3>
            <form method="post" asp-action="AddProduct" class="stack-form" onsubmit="return confirmAddProduct(this)">
                <input name="nev" placeholder="Termék neve" required />
                <input name="kod" placeholder="Kód" required />
                <input name="mennyiseg" type="number" placeholder="Mennyiség" min="1" required />
                <input name="egysegar" type="number" placeholder="Egységár" min="0" required />
                <button type="submit">➕ Hozzáadás</button>
            </form>
        </div>

        <div class="card">
            <h3>Bevételezés / Kiadás</h3>
            <form method="post" asp-action="MoveStock" class="stack-form" onsubmit="return confirmMoveStock(this)">
                <input name="kod" placeholder="Termék kódja" required />

                <select name="tipus">
                    <option value="Bevételezés">Bevételezés</option>
                    <option value="Kiadás">Kiadás</option>
                </select>

                <input name="mennyiseg" type="number" placeholder="Mennyiség" min="1" required />

                <input name="megjegyzes"
                       placeholder="Megjegyzés (pl. áru beérkezése, selejt, kiadás oka)"
                       required />

                <button type="submit">💾 Mentés</button>
            </form>
        </div>
    </div>

    <div class="card">
        <h3>Készletlista</h3>
        <table>
            <thead>
                <tr>
                    <th>Termék</th>
                    <th>Kód</th>
                    <th>Készlet</th>
                    <th>Egységár</th>
                    <th>Utolsó módosítás</th>
                    @if (canManageProducts)
                    {
                        <th>Műveletek</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Products == null || !Model.Products.Any())
                {
                    <tr>
                        <td colspan="6" class="muted">📦 Még nincs rögzített termék.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.Products)
                    {
                        <tr>
                            <td>@item.Nev</td>
                            <td>@item.Kod</td>
                            <td class="@(item.Mennyiseg <= 5 ? "low-stock" : "")">
    @item.Mennyiseg
    @if (item.Mennyiseg <= 5)
    {
        <span class="stock-warning-icon" title="Alacsony raktárkészlet">⚠</span>
    }
</td>
                            <td>@item.Egysegar Ft</td>
                            <td>@item.Modositva</td>

                            @if (canManageProducts)
                            {
                                <td>
                                    <details>
                                        <summary>Módosítás</summary>

                                        <form method="post" asp-action="UpdateProduct" class="mini-form" onsubmit="return confirm('Biztosan menteni szeretnéd a módosításokat?');">
                                            <input type="hidden" name="oldKod" value="@item.Kod" />
                                            <input name="nev" value="@item.Nev" required />
                                            <input name="kod" value="@item.Kod" required />
                                            <input name="mennyiseg" type="number" value="@item.Mennyiseg" min="0" required />
                                            <input name="egysegar" type="number" value="@item.Egysegar" min="0" required />
                                            <button type="submit">💾 Mentés</button>
                                        </form>

                                        @if (item.Mennyiseg > 0)
                                        {
                                            <button type="button" class="danger" disabled title="Nem törölhető, amíg van készleten">
                                                🚫 Nem törölhető
                                            </button>
                                        }
                                        else
                                        {
                                            <form method="post" asp-action="DeleteProduct" onsubmit="return confirm('Biztosan törlöd?');">
                                                <input type="hidden" name="kod" value="@item.Kod" />
                                                <button type="submit" class="danger">🗑️ Törlés</button>
                                            </form>
                                        }
                                    </details>
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card">
        <h3>Mozgásnapló</h3>

        <form method="get" asp-action="Index" class="log-filter">
            <input type="text"
                   name="logSearch"
                   value="@Model.LogSearch"
                   placeholder="Terméknév vagy kód" />

            <select name="logTipus">
                @if (selectedTipus == "Új termék")
                {
                    <option value="">Minden művelet</option>
                    <option value="Új termék" selected>Új termék</option>
                    <option value="Bevételezés">Bevételezés</option>
                    <option value="Kiadás">Kiadás</option>
                    <option value="Módosítás">Módosítás</option>
                    <option value="Törlés">Törlés</option>
                }
                else if (selectedTipus == "Bevételezés")
                {
                    <option value="">Minden művelet</option>
                    <option value="Új termék">Új termék</option>
                    <option value="Bevételezés" selected>Bevételezés</option>
                    <option value="Kiadás">Kiadás</option>
                    <option value="Módosítás">Módosítás</option>
                    <option value="Törlés">Törlés</option>
                }
                else if (selectedTipus == "Kiadás")
                {
                    <option value="">Minden művelet</option>
                    <option value="Új termék">Új termék</option>
                    <option value="Bevételezés">Bevételezés</option>
                    <option value="Kiadás" selected>Kiadás</option>
                    <option value="Módosítás">Módosítás</option>
                    <option value="Törlés">Törlés</option>
                }
                else if (selectedTipus == "Módosítás")
                {
                    <option value="">Minden művelet</option>
                    <option value="Új termék">Új termék</option>
                    <option value="Bevételezés">Bevételezés</option>
                    <option value="Kiadás">Kiadás</option>
                    <option value="Módosítás" selected>Módosítás</option>
                    <option value="Törlés">Törlés</option>
                }
                else if (selectedTipus == "Törlés")
                {
                    <option value="">Minden művelet</option>
                    <option value="Új termék">Új termék</option>
                    <option value="Bevételezés">Bevételezés</option>
                    <option value="Kiadás">Kiadás</option>
                    <option value="Módosítás">Módosítás</option>
                    <option value="Törlés" selected>Törlés</option>
                }
                else
                {
                    <option value="" selected>Minden művelet</option>
                    <option value="Új termék">Új termék</option>
                    <option value="Bevételezés">Bevételezés</option>
                    <option value="Kiadás">Kiadás</option>
                    <option value="Módosítás">Módosítás</option>
                    <option value="Törlés">Törlés</option>
                }
            </select>

            <input type="text"
                   name="logUser"
                   value="@Model.LogUser"
                   placeholder="Végrehajtó" />

            <input type="date"
                   name="logDateFrom"
                   value="@Model.LogDateFrom" />

            <input type="date"
                   name="logDateTo"
                   value="@Model.LogDateTo" />

            <button type="submit">🔎 Szűrés</button>
            <a asp-action="Index" class="link-button">✖ Törlés</a>
        </form>

        <table>
            <thead>
                <tr>
                    <th>Dátum</th>
                    <th>Típus</th>
                    <th>Termék</th>
                    <th>Kód</th>
                    <th>Mennyiség</th>
                    <th>Készlet utána</th>
                    <th>Megjegyzés</th>
                    <th>Végrehajtotta</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Logs == null || !Model.Logs.Any())
                {
                    <tr>
                        <td colspan="8" class="muted">Nincs megjeleníthető naplóbejegyzés.</td>
                    </tr>
                }
                else
                {
                    @foreach (var log in Model.Logs)
                    {
                        <tr>
                            <td>@log.Datum</td>
                            <td>
                                @if (log.Tipus == "Bevételezés")
                                {
                                    <span class="log-badge log-in">@log.Tipus</span>
                                }
                                else if (log.Tipus == "Kiadás")
                                {
                                    <span class="log-badge log-out">@log.Tipus</span>
                                }
                                else if (log.Tipus == "Új termék")
                                {
                                    <span class="log-badge log-new">@log.Tipus</span>
                                }
                                else if (log.Tipus == "Módosítás")
                                {
                                    <span class="log-badge log-edit">@log.Tipus</span>
                                }
                                else if (log.Tipus == "Törlés")
                                {
                                    <span class="log-badge log-delete">@log.Tipus</span>
                                }
                                else
                                {
                                    <span>@log.Tipus</span>
                                }
                            </td>
                            <td>@log.TermekNev</td>
                            <td>@log.TermekKod</td>
                            <td>@log.Mennyiseg</td>
                            <td>@log.KeszletUtana</td>
                            <td>@log.Megjegyzes</td>
                            <td>@log.Vegrehajto</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (isAdmin)
    {
        <div class="card">
            <h3>Dolgozók kezelése</h3>
            <form method="post" asp-action="AddUser" class="inline-form" onsubmit="return confirm('Biztosan létrehozod az új dolgozót?');">
                <input name="username" placeholder="Felhasználónév" required />
                <input name="password" type="password" placeholder="Jelszó" required />
                <select name="role">
                    <option value="admin">admin</option>
                    <option value="raktaros" selected>raktaros</option>
                    <option value="vezeto">vezeto</option>
                </select>
                <button type="submit">👤 Dolgozó felvétele</button>
            </form>

            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Felhasználónév</th>
                        <th>Jogosultság</th>
                        <th>Aktív</th>
                        <th>Létrehozva</th>
                        <th>Törlés</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users == null || !Model.Users.Any())
                    {
                        <tr>
                            <td colspan="6" class="muted">Nincs megjeleníthető felhasználó.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var u in Model.Users)
                        {
                            <tr>
                                <td>@u.Id</td>
                                <td>@u.Username</td>
                                <td>@u.Role</td>
                                <td>@(u.Aktiv == 1 ? "Igen" : "Nem")</td>
                                <td>@u.Letrehozva</td>
                                <td>
                                    <form method="post" asp-action="DeleteUser" onsubmit="return confirm('Biztosan törlöd?');">
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button type="submit" class="danger">🗑️ Törlés</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
    function confirmMoveStock(form) {
        const kod = form.kod.value.trim();
        const tipus = form.tipus.value;
        const mennyiseg = form.mennyiseg.value;
        const megjegyzes = form.megjegyzes ? form.megjegyzes.value.trim() : "";

        if (!kod) {
            alert("A termékkód megadása kötelező!");
            return false;
        }

        if (!mennyiseg || Number(mennyiseg) <= 0) {
            alert("A mennyiségnek 0-nál nagyobbnak kell lennie!");
            return false;
        }

        if (!megjegyzes) {
            alert("A megjegyzés megadása kötelező!");
            return false;
        }

        const uzenet =
            "Biztosan menteni szeretnéd az alábbi műveletet?\n\n" +
            "Termékkód: " + kod + "\n" +
            "Művelet típusa: " + tipus + "\n" +
            "Mennyiség: " + mennyiseg + "\n" +
            "Megjegyzés: " + megjegyzes;

        return confirm(uzenet);
    }

    function confirmAddProduct(form) {
        const nev = form.nev.value.trim();
        const kod = form.kod.value.trim();
        const mennyiseg = form.mennyiseg.value;
        const egysegar = form.egysegar.value;

        if (!nev || !kod) {
            alert("A termék neve és kódja kötelező!");
            return false;
        }

        if (!mennyiseg || Number(mennyiseg) <= 0) {
            alert("A mennyiségnek 0-nál nagyobbnak kell lennie!");
            return false;
        }

        if (Number(egysegar) < 0) {
            alert("Az egységár nem lehet negatív!");
            return false;
        }

        const uzenet =
            "Biztosan menteni szeretnéd az alábbi új terméket?\n\n" +
            "Név: " + nev + "\n" +
            "Kód: " + kod + "\n" +
            "Mennyiség: " + mennyiseg + "\n" +
            "Egységár: " + egysegar;

        return confirm(uzenet);
    }

    document.addEventListener("DOMContentLoaded", function () {
        const kodInput = document.querySelector('input[name="kod"]');
        if (kodInput) {
            kodInput.focus();
        }

        document.querySelectorAll("form").forEach(form => {
            form.addEventListener("submit", function () {
                const btn = form.querySelector("button");
                if (btn) {
                    btn.disabled = true;
                }
            });
        });
    });

    setTimeout(() => {
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(alert => {
            alert.style.transition = 'opacity 0.5s';
            alert.style.opacity = '0';
            setTimeout(() => alert.remove(), 500);
        });
    }, 3000);
</script>
