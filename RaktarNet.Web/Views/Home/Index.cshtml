@model DashboardViewModel

@if (TempData["Success"] != null)
{
    <script>
        alert('@Html.Raw(TempData["Success"])');
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        alert('@Html.Raw(TempData["Error"])');
    </script>
}

<div class="topbar">
    <div>
        <strong>RaktarNet</strong>
        <span class="muted">Felhasználó: @Model.CurrentUser?.Username | Jogosultság: @Model.CurrentUser?.Role</span>
    </div>
    <a class="logout" asp-controller="Account" asp-action="Logout">Kijelentkezés</a>
</div>

<div class="container">
    @if (Model.CurrentUser?.Role == "vezeto" || Model.CurrentUser?.Role == "admin")
    {
        <div class="card">
            <h3>Áttekintés</h3>
            <div class="stats">
                <div class="stat"><span>Termékek száma</span><strong>@Model.Products.Count</strong></div>
                <div class="stat"><span>Összes darabszám</span><strong>@Model.Products.Sum(x => x.Mennyiseg)</strong></div>
                <div class="stat"><span>Összes készletérték</span><strong>@String.Format("{0:N0} Ft", Model.Products.Sum(x => x.Mennyiseg * x.Egysegar))</strong></div>
                <div class="stat"><span>Naplóbejegyzések</span><strong>@Model.Logs.Count</strong></div>

                <div class="stat"><span>Mai mozgások</span><strong>@Model.MaiMozgasokSzama</strong></div>
                <div class="stat"><span>Mai bevételezések</span><strong>@Model.MaiBevetelezesekSzama</strong></div>
                <div class="stat"><span>Mai kiadások</span><strong>@Model.MaiKiadasokSzama</strong></div>
                <div class="stat"><span>Alacsony készletű termékek</span><strong>@Model.AlacsonyKeszletuTermekekSzama</strong></div>
            </div>
        </div>
    }

    <div class="grid">
        <div class="card">
            <h3>Készlet keresése</h3>
            <form method="get" class="inline-form">
                <input type="text" name="search" value="@Model.Search" placeholder="Termék vagy kód" />
                <button type="submit">Keresés</button>
            </form>

            <h3>Új termék</h3>
            <form method="post" asp-action="AddProduct" class="stack-form" onsubmit="return confirmAddProduct(this)">
                <input name="nev" placeholder="Termék neve" required />
                <input name="kod" placeholder="Kód" required />
                <input name="mennyiseg" type="number" placeholder="Mennyiség" min="1" required />
                <input name="egysegar" type="number" placeholder="Egységár" min="0" required />
                <button type="submit">Hozzáadás</button>
            </form>
        </div>

        <div class="card">
            <h3>Bevételezés / Kiadás</h3>
            <form method="post" asp-action="MoveStock" class="stack-form" onsubmit="return confirmMoveStock(this)">
                <input name="kod" placeholder="Termék kódja" required />
                <select name="tipus">
                    <option value="Bevételezés">Bevételezés</option>
                    <option value="Kiadás">Kiadás</option>
                </select>
                <input name="mennyiseg" type="number" placeholder="Mennyiség" min="1" required />
                <input name="megjegyzes" placeholder="Megjegyzés" />
                <button type="submit">Mentés</button>
            </form>
        </div>
    </div>

    <div class="card">
        <h3>Készletlista</h3>
        <table>
            <thead>
                <tr>
                    <th>Termék</th>
                    <th>Kód</th>
                    <th>Készlet</th>
                    <th>Egységár</th>
                    <th>Utolsó módosítás</th>
                    <th>Műveletek</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Products)
            {
                <tr>
                    <td>@item.Nev</td>
                    <td>@item.Kod</td>
                    <td>@item.Mennyiseg</td>
                    <td>@item.Egysegar Ft</td>
                    <td>@item.Modositva</td>
                    <td>
                        @if (Model.CurrentUser?.Role == "vezeto" || Model.CurrentUser?.Role == "admin")
                        {
                            <details>
                                <summary>Módosítás</summary>

                                <form method="post" asp-action="UpdateProduct" class="mini-form" onsubmit="return confirm('Biztosan menteni szeretnéd a módosításokat?');">
                                    <input type="hidden" name="oldKod" value="@item.Kod" />
                                    <input name="nev" value="@item.Nev" required />
                                    <input name="kod" value="@item.Kod" required />
                                    <input name="mennyiseg" type="number" value="@item.Mennyiseg" min="0" required />
                                    <input name="egysegar" type="number" value="@item.Egysegar" min="0" required />
                                    <button type="submit">Mentés</button>
                                </form>

                                <form method="post" asp-action="DeleteProduct" onsubmit="return confirm('Biztosan törlöd?');">
                                    <input type="hidden" name="kod" value="@item.Kod" />
                                    <button type="submit" class="danger">Törlés</button>
                                </form>
                            </details>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="card">
        <h3>Mozgásnapló</h3>

        <form method="get" asp-action="Index" class="log-filter">
            <input type="text"
                   name="logSearch"
                   value="@Model.LogSearch"
                   placeholder="Terméknév vagy kód" />

            <select name="logTipus">
                <option value="">Minden művelet</option>
                <option value="Új termék" @(Model.LogTipus == "Új termék" ? "selected" : "")>Új termék</option>
                <option value="Bevételezés" @(Model.LogTipus == "Bevételezés" ? "selected" : "")>Bevételezés</option>
                <option value="Kiadás" @(Model.LogTipus == "Kiadás" ? "selected" : "")>Kiadás</option>
            </select>

            <input type="text"
                   name="logUser"
                   value="@Model.LogUser"
                   placeholder="Végrehajtó" />

            <input type="date"
                   name="logDateFrom"
                   value="@Model.LogDateFrom" />

            <input type="date"
                   name="logDateTo"
                   value="@Model.LogDateTo" />

            <button type="submit">Szűrés</button>
            <a asp-action="Index">Törlés</a>
        </form>

        <form method="get" asp-action="ExportLogsCsv" class="log-filter">
            <input type="hidden" name="logSearch" value="@Model.LogSearch" />
            <input type="hidden" name="logTipus" value="@Model.LogTipus" />
            <input type="hidden" name="logUser" value="@Model.LogUser" />
            <input type="hidden" name="logDateFrom" value="@Model.LogDateFrom" />
            <input type="hidden" name="logDateTo" value="@Model.LogDateTo" />
            <button type="submit">Mozgásnapló export CSV</button>
        </form>

        <table>
            <thead>
                <tr>
                    <th>Dátum</th>
                    <th>Típus</th>
                    <th>Termék</th>
                    <th>Kód</th>
                    <th>Mennyiség</th>
                    <th>Készlet utána</th>
                    <th>Megjegyzés</th>
                    <th>Végrehajtotta</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var log in Model.Logs)
            {
                <tr>
                    <td>@log.Datum</td>
                    <td>@log.Tipus</td>
                    <td>@log.TermekNev</td>
                    <td>@log.TermekKod</td>
                    <td>@log.Mennyiseg</td>
                    <td>@log.KeszletUtana</td>
                    <td>@log.Megjegyzes</td>
                    <td>@log.Vegrehajto</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model.CurrentUser?.Role == "admin")
    {
        <div class="card">
            <h3>Dolgozók kezelése</h3>
            <form method="post" asp-action="AddUser" class="inline-form" onsubmit="return confirm('Biztosan létrehozod az új dolgozót?');">
                <input name="username" placeholder="Felhasználónév" required />
                <input name="password" type="password" placeholder="Jelszó" required />
                <select name="role">
                    <option value="admin">admin</option>
                    <option value="raktaros" selected>raktaros</option>
                    <option value="vezeto">vezeto</option>
                </select>
                <button type="submit">Dolgozó felvétele</button>
            </form>

            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Felhasználónév</th>
                        <th>Jogosultság</th>
                        <th>Aktív</th>
                        <th>Létrehozva</th>
                        <th>Törlés</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td>@u.Username</td>
                        <td>@u.Role</td>
                        <td>@(u.Aktiv == 1 ? "Igen" : "Nem")</td>
                        <td>@u.Letrehozva</td>
                        <td>
                            <form method="post" asp-action="DeleteUser" onsubmit="return confirm('Biztosan törlöd?');">
                                <input type="hidden" name="id" value="@u.Id" />
                                <button type="submit" class="danger">Törlés</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
    function confirmMoveStock(form) {
        const kod = form.kod.value;
        const tipus = form.tipus.value;
        const mennyiseg = form.mennyiseg.value;
        const megjegyzes = form.megjegyzes ? form.megjegyzes.value : "";

        const uzenet =
            "Biztosan menteni szeretnéd az alábbi műveletet?\n\n" +
            "Termékkód: " + kod + "\n" +
            "Művelet típusa: " + tipus + "\n" +
            "Mennyiség: " + mennyiseg + "\n" +
            "Megjegyzés: " + (megjegyzes ? megjegyzes : "-");

        return confirm(uzenet);
    }

    function confirmAddProduct(form) {
        const nev = form.nev.value;
        const kod = form.kod.value;
        const mennyiseg = form.mennyiseg.value;
        const egysegar = form.egysegar.value;

        const uzenet =
            "Biztosan menteni szeretnéd az alábbi új terméket?\n\n" +
            "Név: " + nev + "\n" +
            "Kód: " + kod + "\n" +
            "Mennyiség: " + mennyiseg + "\n" +
            "Egységár: " + egysegar;

        return confirm(uzenet);
    }
</script>
