<div class="login-page">

    <div class="modern-login-card">

        <!-- BAL OLDAL -->
        <div class="modern-login-left">
            <div class="brand-block">
                <h1 class="brand-title">
                    <span class="brand-white">Raktar</span><span class="brand-blue">Net</span>
                </h1>

                <p class="brand-subtitle">
                    Készletkezelés vállalati környezetben
                </p>

                <div class="brand-icon-box">
                    <span class="brand-icon">📦</span>
                </div>
            </div>
        </div>

        <!-- JOBB OLDAL -->
        <div class="modern-login-right">

            <h2>Bejelentkezés</h2>
            <p class="login-description">
                Kérjük, adja meg felhasználónevét és jelszavát.
            </p>

            <form method="post" class="login-form-modern">

                <label>Felhasználónév</label>
                <input asp-for="Username" />

                <label>Jelszó</label>
                <div class="password-wrap-modern">
                    <input asp-for="Password" type="password" id="passwordInput" />
                    <button type="button"
                            class="toggle-password-modern"
                            onmousedown="showPassword()"
                            onmouseup="hidePassword()"
                            onmouseleave="hidePassword()">
                        👁
                    </button>
                </div>

                <button type="submit" class="login-submit-btn">
                    Belépés
                </button>

            </form>

            <div class="login-footer-note">
                © 2025 RaktarNet. Minden jog fenntartva.
            </div>

        </div>

    </div>

</div>

<script>
    function showPassword() {
        document.getElementById("passwordInput").type = "text";
    }

    function hidePassword() {
        document.getElementById("passwordInput").type = "password";
    }
</script>
